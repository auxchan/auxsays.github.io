---
---
@import "main";

@font-face {
  font-family: 'AUX Triad Fusion';
  src: url('{{ "/assets/fonts/AUX-TriadFusion-v13-Regular.otf" | relative_url }}') format('opentype');
  font-display: swap;
}

.post h1,
.post h2,
.post h3,
.post-title,
#post-list h1,
#post-list h2,
#post-list h3,
.sidebar .site-title {
  font-family: 'AUX Triad Fusion', 'Inter', 'Segoe UI', sans-serif;
  letter-spacing: 0.03em;
}
